{
    "name": "asimnexus-desktop",
    "version": "1.0.0",
    "description": "ASIMNEXUS Desktop App — Electron Wrapper",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "NODE_ENV=development electron .",
        "build:win": "electron-builder --win",
        "build:mac": "electron-builder --mac",
        "build:linux": "electron-builder --linux",
        "build:all": "electron-builder --win --mac --linux",
        "postinstall": "electron-builder install-app-deps"
    },
    "build": {
        "appId": "app.asimnexus.desktop",
        "productName": "ASIMNEXUS",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "icons/**/*"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "icons/icon.ico",
            "artifactName": "ASIMNEXUS-Setup-${version}.${ext}"
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "icon": "icons/icon.icns",
            "category": "public.app-category.productivity"
        },
        "linux": {
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "deb",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "icons",
            "category": "Utility"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "ASIMNEXUS"
        },
        "publish": {
            "provider": "github",
            "owner": "asimnexus",
            "repo": "asimnexus-desktop"
        }
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.0.0",
        "electron-updater": "^6.0.0"
    },
    "dependencies": {
        "electron-updater": "^6.0.0"
    }
}