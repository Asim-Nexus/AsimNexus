{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "http://localhost:8080",
    "distDir": "../pwa"
  },
  "package": {
    "productName": "AsimNexus",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "window": {
        "all": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["http://localhost:8080/**", "https://**"]
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.asimnexus.app",
      "icon": [
        "../pwa/icons/icon-192.png",
        "../pwa/icons/icon-512.png"
      ],
      "targets": "all",
      "windows": {
        "wix": {
          "language": "en-US"
        }
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8080 https://*; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: https://*"
    },
    "windows": [
      {
        "title": "AsimNexus — World Operating System",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ]
  }
}
