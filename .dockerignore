# AsimNexus .dockerignore
# ========================
# Exclude unnecessary files from Docker build context for faster builds.

# Version control
.git
.gitignore
.gitattributes
.github

# Environment
.env
.env.*
*.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# Node / Frontend (handled separately in frontend Dockerfile)
node_modules/
frontend/node_modules/
frontend/build/
frontend/.cache

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
/logs/

# Data (persistent volumes, not in image)
/data/
/database/*.db
/database/*.sqlite

# Documentation (not needed at runtime)
docs/
plans/
*.md
LICENSE-*

# Tests (not needed at runtime)
tests/
_test_*.py
_live_test.py

# Scripts (not needed at runtime)
scripts/
*.ps1

# Monitoring configs (mounted separately)
monitoring/

# Infrastructure configs (mounted separately)
infrastructure/

# Models (downloaded at runtime or mounted)
models/*.bin
models/*.gguf
