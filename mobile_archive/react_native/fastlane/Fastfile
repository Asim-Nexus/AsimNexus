# Fastlane for ASIMNEXUS Mobile App Store Submission
# Install: gem install fastlane -NV
# Setup: fastlane init

platform :ios do
  desc "Build and upload iOS app to App Store Connect"
  lane :deploy do
    # 1. Build the app with gym
    gym(
      scheme: "AsimNexus",
      export_method: "app-store",
      clean: true,
      configuration: "Release"
    )

    # 2. Upload to App Store Connect
    pilot(
      apple_id: ENV["APPLE_ID"],
      app_identifier: "com.asimnexus.worldos",
      skip_waiting_for_build_processing: true,
      changelog: get_changelog
    )

    # 3. Upload metadata (screenshots, description, etc.)
    deliver(
      app_identifier: "com.asimnexus.worldos",
      force: true,
      skip_screenshots: false,
      skip_metadata: false,
      metadata_path: "./fastlane/metadata/ios"
    )

    # 4. Notify team
    slack(
      message: "iOS App v#{get_version} submitted to App Store!",
      success: true
    )
  end

  desc "Take screenshots for App Store"
  lane :screenshots do
    capture_screenshots(
      devices: ["iPhone_15_Pro_Max", "iPhone_15_Pro", "iPhone_SE_3rd_gen"],
      languages: ["en-US"],
      output_directory: "./fastlane/screenshots/ios"
    )
  end
end

platform :android do
  desc "Build and upload Android app to Google Play"
  lane :deploy do
    # 1. Build the AAB
    gradle(
      task: "bundleRelease",
      project_dir: "../android"
    )

    # 2. Upload to Google Play Console
    upload_to_play_store(
      track: "production",
      release_status: "completed",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"],
      package_name: "com.asimnexus.worldos",
      changelog: get_changelog
    )

    # Notify team
    slack(
      message: "Android App v#{get_version} submitted to Google Play!",
      success: true
    )
  end

  desc "Deploy to internal testing track"
  lane :internal_test do
    gradle(task: "bundleRelease")
    upload_to_play_store(
      track: "internal",
      release_status: "draft",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"],
      package_name: "com.asimnexus.worldos"
    )
  end
end

# Shared helpers
def get_version
  version = `npx -c 'echo $npm_package_version'`.strip
  version.empty? ? "1.0.0" : version
end

def get_changelog
  "Bug fixes and performance improvements"
end
