{
    "__inputs": [],
    "__requires": [],
    "dashboard": {
        "title": "ASIMNEXUS Production Overview",
        "description": "Comprehensive production monitoring dashboard for ASIMNEXUS — core API, sector API, database, cache, and infrastructure.",
        "uid": "asimnexus-overview",
        "tags": [
            "asimnexus",
            "production",
            "monitoring"
        ],
        "timezone": "browser",
        "editable": true,
        "refresh": "30s",
        "time": {
            "from": "now-6h",
            "to": "now"
        },
        "timepicker": {
            "refresh_intervals": [
                "5s",
                "10s",
                "30s",
                "1m",
                "5m",
                "15m",
                "30m",
                "1h",
                "2h",
                "1d"
            ]
        },
        "templating": {
            "list": [
                {
                    "name": "env",
                    "type": "constant",
                    "label": "Environment",
                    "query": "production",
                    "current": {
                        "text": "production",
                        "value": "production"
                    }
                },
                {
                    "name": "cluster",
                    "type": "constant",
                    "label": "Cluster",
                    "query": "asimnexus",
                    "current": {
                        "text": "asimnexus",
                        "value": "asimnexus"
                    }
                }
            ]
        },
        "panels": [
            {
                "id": 1,
                "title": "Core API — Request Rate",
                "type": "graph",
                "span": 6,
                "height": "250px",
                "datasource": "Prometheus",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "sum(rate(http_requests_total{job=\"asimnexus-core\"}[5m]))",
                        "legendFormat": "core-api",
                        "refId": "A"
                    },
                    {
                        "expr": "sum(rate(http_requests_total{job=\"asimnexus-sector-api\"}[5m]))",
                        "legendFormat": "sector-api",
                        "refId": "B"
                    }
                ],
                "yaxes": [
                    {
                        "format": "reqps",
                        "label": "Requests/s"
                    },
                    {
                        "format": "short",
                        "show": false
                    }
                ],
                "legend": {
                    "show": true,
                    "values": true,
                    "min": true,
                    "max": true,
                    "avg": true
                }
            },
            {
                "id": 2,
                "title": "Error Rate (5xx)",
                "type": "graph",
                "span": 6,
                "height": "250px",
                "datasource": "Prometheus",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "sum(rate(http_requests_total{job=\"asimnexus-core\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"asimnexus-core\"}[5m]))",
                        "legendFormat": "core-api %",
                        "refId": "A"
                    },
                    {
                        "expr": "sum(rate(http_requests_total{job=\"asimnexus-sector-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"asimnexus-sector-api\"}[5m]))",
                        "legendFormat": "sector-api %",
                        "refId": "B"
                    }
                ],
                "yaxes": [
                    {
                        "format": "percentunit",
                        "label": "Error Rate"
                    },
                    {
                        "format": "short",
                        "show": false
                    }
                ],
                "legend": {
                    "show": true,
                    "values": true,
                    "min": true,
                    "max": true,
                    "avg": true
                }
            },
            {
                "id": 3,
                "title": "p95 Latency",
                "type": "graph",
                "span": 6,
                "height": "250px",
                "datasource": "Prometheus",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 8
                },
                "targets": [
                    {
                        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"asimnexus-core\"}[5m])) by (le))",
                        "legendFormat": "core-api",
                        "refId": "A"
                    },
                    {
                        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"asimnexus-sector-api\"}[5m])) by (le))",
                        "legendFormat": "sector-api",
                        "refId": "B"
                    }
                ],
                "yaxes": [
                    {
                        "format": "s",
                        "label": "Latency"
                    },
                    {
                        "format": "short",
                        "show": false
                    }
                ],
                "legend": {
                    "show": true,
                    "values": true,
                    "min": true,
                    "max": true,
                    "avg": true
                },
                "lines": true,
                "fill": 1
            },
            {
                "id": 4,
                "title": "HTTP Status Code Distribution",
                "type": "graph",
                "span": 6,
                "height": "250px",
                "datasource": "Prometheus",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 8
                },
                "targets": [
                    {
                        "expr": "sum(rate(http_requests_total{job=\"asimnexus-core\",status=~\"2..\"}[5m]))",
                        "legendFormat": "2xx",
                        "refId": "A"
                    },
                    {
                        "expr": "sum(rate(http_requests_total{job=\"asimnexus-core\",status=~\"4..\"}[5m]))",
                        "legendFormat": "4xx",
                        "refId": "B"
                    },
                    {
                        "expr": "sum(rate(http_requests_total{job=\"asimnexus-core\",status=~\"5..\"}[5m]))",
                        "legendFormat": "5xx",
                        "refId": "C"
                    }
                ],
                "yaxes": [
                    {
                        "format": "reqps",
                        "label": "Requests/s"
                    },
                    {
                        "format": "short",
                        "show": false
                    }
                ]
            },
            {
                "id": 5,
                "title": "Pod CPU Usage",
                "type": "graph",
                "span": 4,
                "height": "200px",
                "datasource": "Prometheus",
                "gridPos": {
                    "h": 8,
                    "w": 8,
                    "x": 0,
                    "y": 16
                },
                "targets": [
                    {
                        "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"asimnexus\"}[5m])) by (pod)",
                        "legendFormat": "{{ pod }}",
                        "refId": "A"
                    }
                ],
                "yaxes": [
                    {
                        "format": "percentunit",
                        "label": "CPU"
                    },
                    {
                        "format": "short",
                        "show": false
                    }
                ]
            },
            {
                "id": 6,
                "title": "Pod Memory Usage",
                "type": "graph",
                "span": 4,
                "height": "200px",
                "datasource": "Prometheus",
                "gridPos": {
                    "h": 8,
                    "w": 8,
                    "x": 8,
                    "y": 16
                },
                "targets": [
                    {
                        "expr": "sum(container_memory_working_set_bytes{namespace=\"asimnexus\"}) by (pod)",
                        "legendFormat": "{{ pod }}",
                        "refId": "A"
                    }
                ],
                "yaxes": [
                    {
                        "format": "bytes",
                        "label": "Memory"
                    },
                    {
                        "format": "short",
                        "show": false
                    }
                ]
            },
            {
                "id": 7,
                "title": "Pod Restarts",
                "type": "stat",
                "span": 4,
                "height": "200px",
                "datasource": "Prometheus",
                "gridPos": {
                    "h": 8,
                    "w": 8,
                    "x": 16,
                    "y": 16
                },
                "targets": [
                    {
                        "expr": "sum(rate(kube_pod_container_status_restarts_total{namespace=\"asimnexus\"}[30m])) by (pod)",
                        "legendFormat": "{{ pod }}",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "custom": {
                            "displayMode": "list"
                        },
                        "color": {
                            "mode": "thresholds"
                        },
                        "thresholds": {
                            "mode": "absolute",
                            "steps": [
                                {
                                    "color": "green",
                                    "value": null
                                },
                                {
                                    "color": "yellow",
                                    "value": 1
                                },
                                {
                                    "color": "red",
                                    "value": 3
                                }
                            ]
                        }
                    }
                }
            },
            {
                "id": 8,
                "title": "PostgreSQL Connections",
                "type": "graph",
                "span": 6,
                "height": "200px",
                "datasource": "Prometheus",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 24
                },
                "targets": [
                    {
                        "expr": "pg_stat_activity_count{datname=\"asimnexus\"}",
                        "legendFormat": "active connections",
                        "refId": "A"
                    }
                ],
                "yaxes": [
                    {
                        "format": "short",
                        "label": "Connections"
                    },
                    {
                        "format": "short",
                        "show": false
                    }
                ]
            },
            {
                "id": 9,
                "title": "Redis Memory Usage",
                "type": "graph",
                "span": 6,
                "height": "200px",
                "datasource": "Prometheus",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 24
                },
                "targets": [
                    {
                        "expr": "redis_memory_used_bytes{job=\"redis\"}",
                        "legendFormat": "used",
                        "refId": "A"
                    },
                    {
                        "expr": "redis_memory_max_bytes{job=\"redis\"}",
                        "legendFormat": "max",
                        "refId": "B"
                    }
                ],
                "yaxes": [
                    {
                        "format": "bytes",
                        "label": "Memory"
                    },
                    {
                        "format": "short",
                        "show": false
                    }
                ]
            },
            {
                "id": 10,
                "title": "Security: 401/429 Rate",
                "type": "graph",
                "span": 6,
                "height": "200px",
                "datasource": "Prometheus",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 32
                },
                "targets": [
                    {
                        "expr": "rate(http_requests_total{job=\"asimnexus-core\",status=\"401\"}[5m])",
                        "legendFormat": "401 Unauthorized",
                        "refId": "A"
                    },
                    {
                        "expr": "rate(http_requests_total{job=\"asimnexus-core\",status=\"429\"}[5m])",
                        "legendFormat": "429 Rate Limited",
                        "refId": "B"
                    }
                ],
                "yaxes": [
                    {
                        "format": "reqps",
                        "label": "Requests/s"
                    },
                    {
                        "format": "short",
                        "show": false
                    }
                ]
            },
            {
                "id": 11,
                "title": "Disk Space (Nodes)",
                "type": "gauge",
                "span": 6,
                "height": "200px",
                "datasource": "Prometheus",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 32
                },
                "targets": [
                    {
                        "expr": "min(node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})",
                        "legendFormat": "min disk available",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "percentunit",
                        "min": 0,
                        "max": 1,
                        "color": {
                            "mode": "thresholds"
                        },
                        "thresholds": {
                            "mode": "absolute",
                            "steps": [
                                {
                                    "color": "red",
                                    "value": null
                                },
                                {
                                    "color": "yellow",
                                    "value": 0.1
                                },
                                {
                                    "color": "green",
                                    "value": 0.2
                                }
                            ]
                        }
                    }
                }
            },
            {
                "id": 12,
                "title": "Active Alerts",
                "type": "alertlist",
                "span": 12,
                "height": "250px",
                "datasource": "Prometheus",
                "gridPos": {
                    "h": 10,
                    "w": 24,
                    "x": 0,
                    "y": 40
                },
                "alertlist": {
                    "showOptions": [
                        "current",
                        "ok",
                        "pending"
                    ],
                    "maxItems": 20,
                    "sortOrder": 1
                }
            }
        ],
        "schemaVersion": 27,
        "version": 1
    }
}