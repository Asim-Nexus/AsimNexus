{
    "cli": {
        "version": ">= 7.0.0"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": true
            }
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "app-bundle"
            },
            "ios": {
                "simulator": false
            }
        },
        "production": {
            "autoIncrement": true,
            "android": {
                "buildType": "app-bundle",
                "gradleCommand": ":app:bundleRelease"
            },
            "ios": {
                "autoIncrement": true
            },
            "env": {
                "ASIMNEXUS_API_URL": "https://api.asimnexus.org",
                "EXPO_PUBLIC_API_URL": "https://api.asimnexus.org"
            }
        }
    },
    "submit": {
        "production": {
            "android": {
                "serviceAccountKeyPath": "./secrets/google-play-service-account.json",
                "track": "production",
                "releaseStatus": "completed"
            },
            "ios": {
                "appleId": "apple-developer@asimnexus.org",
                "ascAppId": "com.asimnexus.worldos",
                "appleTeamId": "TEAM_ID",
                "sku": "com.asimnexus.worldos"
            }
        }
    }
}