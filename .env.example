# =============================================================================
# AsimNexus Environment Configuration (.env.example)
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# CRITICAL: Never commit .env to version control. It contains secrets.
# =============================================================================

# ─── Authentication & Security ──────────────────────────────────────────────
# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: If not set, a hardcoded fallback is used (not safe for production!)
ASIM_JWT_SECRET=

# JWT token expiry (hours, default: 24)
ASIM_TOKEN_EXPIRY_HOURS=24

# JWT refresh token expiry (hours, default: 168 = 7 days)
ASIM_REFRESH_EXPIRY_HOURS=168

# CORS allowed origins (comma-separated, no default = secure)
# Example: http://localhost:3000,https://app.asimnexus.com
ASIM_ALLOWED_ORIGINS=

# ─── Backend Core ───────────────────────────────────────────────────────────
# SQLite database path (default: data/asim_core.db)
ASIM_DB_PATH=data/asim_core.db

# Data directory for user files (default: data)
ASIM_DATA_DIR=data

# Project root directory (default: current working directory)
ASIM_ROOT=

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
ASIM_LOG_LEVEL=INFO

# Release channel: stable, rc, beta, dev (default: stable)
ASIM_RELEASE_CHANNEL=stable

# Local GGUF model path for offline inference
ASIM_GGUF_MODEL_PATH=models/Qwen3-4B-distill-deepseek-opus-gemini-Q8_0.gguf

# Frontend/backend API URL (used by React frontend)
REACT_APP_API_URL=http://localhost:8000

# ─── Cloud LLM API Keys (Optional — local-only works without these) ─────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROK_API_KEY=
GOOGLE_API_KEY=

# NVIDIA NIM
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_MODEL=meta/llama-3.1-8b-instruct

# Multiple NVIDIA API keys (JSON object, optional)
ASIM_NVIDIA_API_KEYS={}

# LLM Engine URL (for local LLM provider, default: http://localhost:8000)
LLM_ENGINE_URL=http://localhost:8000

# ─── Dharma / Ethics Engine ─────────────────────────────────────────────────
# Enable Delta-T economic balance engine (default: true)
ASIM_DHARMA_DT_ENGINE=true

# Enable cultural compiler (default: true)
ASIM_DHARMA_CULTURAL=true

# Maximum audit log entries (default: 10000)
ASIM_DHARMA_AUDIT_MAX=10000

# VETO finance threshold in credits (default: 1000)
ASIM_VETO_FINANCE_THRESHOLD=1000

# ZKP token TTL in seconds (default: 300 = 5 minutes)
ASIM_VETO_ZKP_TTL=300

# VETO audit log max entries (default: 10000)
ASIM_VETO_AUDIT_MAX=10000

# ─── AI Router ──────────────────────────────────────────────────────────────
# Prefer local LLM over cloud (default: true)
ASIM_ROUTER_PREFER_LOCAL=true

# Force offline mode (default: false)
ASIM_ROUTER_OFFLINE_MODE=false

# Rate limit: max API calls per window (default: 100)
ASIM_ROUTER_RATE_LIMIT=100

# Rate limit window in seconds (default: 60)
ASIM_ROUTER_RATE_WINDOW=60

# ─── Mesh Network ───────────────────────────────────────────────────────────
# Discovery port (default: 7331)
ASIM_MESH_DISCOVERY_PORT=7331

# Discovery interval in seconds (default: 30)
ASIM_MESH_DISCOVERY_INTERVAL=30

# Beacon interval in seconds (default: 60)
ASIM_MESH_BEACON_INTERVAL=60

# Discovery timeout in seconds (default: 5)
ASIM_MESH_DISCOVERY_TIMEOUT=5

# Stale node max age in seconds (default: 300)
ASIM_MESH_STALE_NODE_AGE=300

# Kademlia DHT — replication parameter K (default: 20)
ASIM_MESH_DHT_K=20

# Kademlia DHT — concurrency parameter alpha (default: 3)
ASIM_MESH_DHT_ALPHA=3

# Kademlia DHT — ID length in bits (default: 160)
ASIM_MESH_DHT_ID_LENGTH=160

# Kademlia DHT — port (default: 7332)
ASIM_MESH_DHT_PORT=7332

# Kademlia DHT — node stale timeout in seconds (default: 3600)
ASIM_MESH_DHT_NODE_STALE_SEC=3600

# Kademlia DHT — max ping failures before marking bad (default: 3)
ASIM_MESH_DHT_MAX_FAILURES=3

# Kademlia DHT — key-value TTL in seconds (default: 86400 = 24h)
ASIM_MESH_DHT_TTL=86400

# P2P transport port (default: 7333)
ASIM_MESH_P2P_PORT=7333

# P2P max connections (default: 50)
ASIM_MESH_P2P_MAX_CONNECTIONS=50

# P2P message timeout in seconds (default: 30)
ASIM_MESH_P2P_MESSAGE_TIMEOUT=30

# Relay port (default: 7334)
ASIM_MESH_RELAY_PORT=7334

# Relay session timeout in seconds (default: 300 = 5 min)
ASIM_MESH_RELAY_SESSION_TIMEOUT=300

# Relay max sessions (default: 100)
ASIM_MESH_RELAY_MAX_SESSIONS=100

# Bootstrap port (default: 7335)
ASIM_MESH_BOOTSTRAP_PORT=7335

# Bootstrap max nodes (default: 50)
ASIM_MESH_BOOTSTRAP_MAX_NODES=50

# Bootstrap node timeout in seconds (default: 3600)
ASIM_MESH_BOOTSTRAP_NODE_TIMEOUT=3600

# Offline sync DB path (default: data/offline_sync.jsonl)
ASIM_SYNC_DB_PATH=data/offline_sync.jsonl

# Offline sync interval in seconds (default: 15)
ASIM_SYNC_INTERVAL=15

# Offline sync batch size (default: 50)
ASIM_SYNC_BATCH_SIZE=50

# Offline sync max retries (default: 5)
ASIM_SYNC_MAX_RETRIES=5

# Offline sync retry backoff in seconds (default: 30)
ASIM_SYNC_RETRY_BACKOFF=30

# Node registry DB path (default: data/node_registry.db)
ASIM_MESH_NODE_REGISTRY_DB=data/node_registry.db

# CRDT operation max age in seconds (default: 86400 = 24h)
ASIM_MESH_CRDT_OP_MAX_AGE=86400

# Default mesh network (default: local)
ASIM_MESH_DEFAULT=local

# Mesh routing DB path (default: data/mesh_routing.jsonl)
ASIM_MESH_DB_PATH=data/mesh_routing.jsonl

# Mesh health check timeout in seconds (default: 10)
ASIM_MESH_HEALTH_TIMEOUT=10

# Auto-switch interval in seconds (default: 30)
ASIM_MESH_AUTO_SWITCH_INTERVAL=30

# Node ID (auto-generated if not set)
ASIM_NODE_ID=

# ─── World Clones ───────────────────────────────────────────────────────────
# World clone API timeout in seconds (default: 15)
ASIM_WORLDCLONE_TIMEOUT=15

# Max concurrent clones (default: 5)
ASIM_WORLDCLONE_MAX_CLONES=5

# Default sector (default: general)
ASIM_WORLDCLONE_DEFAULT_SECTOR=general

# Enable agent mode (default: false)
ASIM_WORLDCLONE_AGENT_MODE=false

# ─── Governance ─────────────────────────────────────────────────────────────
# Consensus quorum percent (default: 51)
ASIM_GOV_QUORUM_PERCENT=51

# Voting period in hours (default: 72)
ASIM_GOV_VOTING_PERIOD_HOURS=72

# Minimum voting weight (default: 1.0)
ASIM_GOV_MIN_VOTING_WEIGHT=1.0

# ─── GPU / ML ───────────────────────────────────────────────────────────────
# Enable GPU acceleration (default: true)
ASIM_GPU_ENABLED=true

# GPU memory limit in GB (default: 6.0)
ASIM_GPU_MEMORY=6.0

# Max batch size (default: 4)
ASIM_BATCH_SIZE=4

# Learning rate (default: 2e-5)
ASIM_LEARNING_RATE=2e-5

# Max sequence length (default: 2048)
ASIM_MAX_SEQ_LENGTH=2048

# Cache directory (default: ./cache)
ASIM_CACHE_DIR=./cache

# ─── Integration API Keys (Optional) ────────────────────────────────────────
# These are optional third-party API keys for integrations.
# The system works without them — only needed for specific features.

STRIPE_API_KEY=
RAZORPAY_API_KEY=
RAZORPAY_API_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
BRAVE_API_KEY=
PERPLEXITY_API_KEY=
TAVILY_API_KEY=
ELEVENLABS_API_KEY=
GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=
GOOGLE_MAPS_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_DRIVE_ACCESS_TOKEN=
GMAIL_ACCESS_TOKEN=
OUTLOOK_ACCESS_TOKEN=
SMTP_HOST=
SMTP_PORT=587
IMAP_HOST=
IMAP_PORT=993
EMAIL_ADDRESS=
EMAIL_PASSWORD=
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=
WHATSAPP_WEBHOOK_SECRET=
NEWS_API_KEY=
COINGECKO_API_KEY=
NASA_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b
SUPABASE_PROJECT_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATABASE_URL=
SUPABASE_KEY=
SUPABASE_URL=
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
MONGODB_URI=
POLLINATIONS_API_KEY=
LOCAL_LLM_BEARER_TOKEN=

# ─── Vault / Secrets Provider ───────────────────────────────────────────────
# Provider: local, aws, hashicorp, azure (default: local)
VAULT_PROVIDER=local
VAULT_ENDPOINT=http://localhost:8200
VAULT_TOKEN=
VAULT_PATH=secret
AWS_REGION=us-east-1
AZURE_VAULT_URL=
ENCRYPTION_KEY=
SECRETS_DIR=.secrets

# ─── Database (PostgreSQL, optional — SQLite is default) ────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=asimnexus
DB_USER=postgres
DB_PASSWORD=postgres
DB_ENCRYPTION_KEY=

# ─── Redis (Optional — for caching/sessions) ────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false

# ─── Compliance ─────────────────────────────────────────────────────────────
# Compliance audit interval in hours (default: 24)
ASIM_COMPLIANCE_AUDIT_HOURS=24

# ─── Security Config ────────────────────────────────────────────────────────
API_RATE_LIMIT=100
SESSION_TIMEOUT=3600
MAX_CONNECTIONS=1000
KEY_ROTATION_HOURS=24

# ─── Federation ─────────────────────────────────────────────────────────────
ASIM_FED_DATA_DIR=data/federation
ASIM_FED_NODE_ID=
ASIM_FED_SYNC_INTERVAL=60
ASIM_FED_MAX_PEERS=10

# ─── Life Journey ───────────────────────────────────────────────────────────
ASIM_LIFE_DB_PATH=data/life_journey.jsonl

# ─── Vector Memory ──────────────────────────────────────────────────────────
ASIM_VECTOR_DB_PATH=data/vector_memory.db
ASIM_EMBEDDING_BACKEND=dummy
ASIM_VECTOR_PRUNE_DAYS=90
ASIM_VECTOR_KEEP_PER_TYPE=100

# ─── Personal OS ────────────────────────────────────────────────────────────
ASIM_POS_DB_PATH=data/personal_os.jsonl

# ─── Power Balance Constitution ─────────────────────────────────────────────
ASIM_POWER_BALANCE_DB_PATH=data/power_balance.jsonl

# ─── Human Override Engine ──────────────────────────────────────────────────
ASIM_OVERRIDE_TTL=600
ASIM_OVERRIDE_AUDIT_MAX=10000
ASIM_OVERRIDE_FINAL_THREE=3

# ─── Agent Contracts ────────────────────────────────────────────────────────
ASIM_AGENT_MAX_RENEWALS=3
ASIM_AGENT_COOLING_OFF_HOURS=72
ASIM_AGENT_EXPIRY_WARNING_HOURS=48

# ─── Consensus Engine ───────────────────────────────────────────────────────
ASIM_CONSENSUS_TIMEOUT=30
ASIM_CONSENSUS_TOTAL_NODES=7
ASIM_CONSENSUS_THRESHOLD=

# ─── Runtime ────────────────────────────────────────────────────────────────
ASIM_RUNTIME_KEY=

# ─── Cloud (Optional) ───────────────────────────────────────────────────────
ASIM_CLOUD_ENABLED=true
ASIM_CLOUD_URL=https://api.asim-nexus.ai
ASIM_CLOUD_API_KEY=
ASIM_WAMP_ENABLED=false
ASIM_WAMP_URL=ws://localhost:8080/ws
ASIM_SECURITY_MODE=strict
ASIM_LOCALE=ne-NP

# ─── Sentry / APM Monitoring ────────────────────────────────────────────
# Sentry DSN — get from https://sentry.io/settings/.../projects/asimnexus/keys/
# Leave empty to disable Sentry APM entirely
SENTRY_DSN=

# Master switch for Sentry APM (default: true)
ASIM_SENTRY_ENABLED=true

# Environment tag sent to Sentry (default: production)
ASIM_SENTRY_ENVIRONMENT=production

# Traces sample rate (0.0–1.0, default: 0.1 = 10%)
ASIM_SENTRY_TRACES_RATE=0.1

# Profiling sample rate (0.0–1.0, default: 0.05 = 5%)
ASIM_SENTRY_PROFILES_RATE=0.05
