# AsimNexus Production Environment Configuration
# ================================================
# Copy this file to .env and fill in all values before deploying.
# NEVER commit the actual .env file to version control.
#
#   cp .env.example .env
#   # then edit .env with your secrets

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
DATABASE_URL=postgresql://asimnexus:${POSTGRES_PASSWORD}@postgres:5432/asimnexus

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── AsimNexus Core ──────────────────────────────────────────────────────────
ASIM_NODE_ID=backend-prod-01
ASIM_ENVIRONMENT=production
ASIM_COUNTRY=NP
ASIM_LOCALE=ne-NP
ASIM_LANGUAGE=ne
ASIM_CURRENCY=NPR
ASIM_LOG_LEVEL=INFO
ASIM_SECURITY_MODE=strict
ASIM_RELEASE_CHANNEL=stable
ASIM_TEST_MODE=false
ASIM_SINGLE_MACHINE_PEERS=

# ── Cloud / AI ───────────────────────────────────────────────────────────────
ASIM_LOCAL_MODEL_ENABLED=false
ASIM_CLOUD_ENABLED=true
ASIM_CLOUD_URL=https://api.asim-nexus.ai

# ── TLS / mTLS ──────────────────────────────────────────────────────────────
ASIM_REQUIRE_MTLS=false
ASIM_REQUIRE_OAUTH2=false

# ── Offline Mode ─────────────────────────────────────────────────────────────
OFFLINE_MODE=false

# ── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ── Frontend ─────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000
